{
  "$schema": "https://raw.githubusercontent.com/aleksey-hoffman/sigma-file-manager/main/packages/api/manifest.schema.json",
  "id": "sigma.excalidraw",
  "name": "Excalidraw",
  "version": "1.0.1",
  "publisher": {
    "name": "sigma-hub",
    "url": "https://github.com/sigma-hub"
  },
  "repository": "https://github.com/sigma-hub/sfm-extension-excalidraw",
  "license": "MIT",
  "files": [
    "dist",
    "icon.png",
    "index.js",
    "locales",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs"
  },
  "categories": [
    "Productivity"
  ],
  "tags": [
    "excalidraw",
    "drawing",
    "whiteboard",
    "diagram"
  ],
  "extensionType": "api",
  "main": "index.js",
  "icon": "icon.png",
  "permissions": [
    "sidebar",
    "dialogs",
    "clipboard",
    "fs.write",
    "openUrl"
  ],
  "activationEvents": [
    "onInstall",
    "onUninstall",
    "onStartup",
    "onUpdate",
    "onEnable",
    "onDisable"
  ],
  "engines": {
    "sigmaFileManager": ">=2.0.0"
  },
  "devDependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@sigma-file-manager/api": "^1.2.0",
    "esbuild": "^0.27.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}